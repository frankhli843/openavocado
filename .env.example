# Open Avocado local configuration.
# Copy to .env.local for local development. Do not commit real secrets.

# Database and runtime artifact storage.
AVOCADOCORE_DB_PATH=data/open-avocado.db
AVOCADOCORE_RUNTIME_ROOT=runtime_artifacts

# The portable default is local-queue. It creates the first assessment and
# deterministic follow-up lessons locally, with no external task system.
# Options: local-queue, noop, webhook, agent-harness, dora-task.
AVOCADOCORE_COMPLETION_ADAPTER=local-queue

# Optional agent harness. The command receives event JSON on stdin and must
# print one JSON object as its last stdout line:
# {"ok":true,"ref":"task-or-run-id","lesson_id":123}
AVOCADOCORE_AGENT_HARNESS_COMMAND=
AVOCADOCORE_AGENT_HARNESS_TIMEOUT_MS=900000

# Optional webhook adapter.
AVOCADOCORE_WEBHOOK_URL=

# Optional compatibility adapter for operators who already have a task CLI or
# task endpoint. This is not required for local setup.
AVOCADOCORE_DORA_ENDPOINT=
AVOCADOCORE_DORA_TODO_CLI=
AVOCADOCORE_DORA_PROJECT=open-avocado

# Optional AI providers for feedback and generation harnesses.
AVOCADOCORE_DEFAULT_PROVIDER=local
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-flash
OPENAI_API_KEY=

# Optional auth for hosted demos.
AVOCADOCORE_AUTH_REQUIRED=false
AVOCADOCORE_SESSION_SECRET=
