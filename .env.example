# AvocadoCore environment configuration example.
# Copy to .env.local (gitignored) for local development or to a deployment-specific file.

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Directory is created automatically.
# Default: data/avocadocore.db (relative to process.cwd())
# AVOCADOCORE_DB_PATH=/var/prodavo/data/avocadocore.db

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set to "true" to require authentication for all pages and API routes.
# For local/frankavo runs: leave unset or set to "false".
# For hosted/prodavo runs: MUST be "true".
AVOCADOCORE_AUTH_REQUIRED=false

# Secret used to sign session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required when AVOCADOCORE_AUTH_REQUIRED=true.
# AVOCADOCORE_SESSION_SECRET=<64-char-hex-string>

# Bootstrap admin account (created once on first startup if username doesn't exist).
# Set only in the production deployment env file; never commit these values.
# AVOCADOCORE_ADMIN_BOOTSTRAP_USER=frank
# AVOCADOCORE_ADMIN_BOOTSTRAP_PASS=<strong-password>
# AVOCADOCORE_ADMIN_BOOTSTRAP_EMAIL=admin@example.local
# AVOCADOCORE_ADMIN_BOOTSTRAP_DISPLAY=Frank

# ── LLM / ACP (optional) ─────────────────────────────────────────────────────
# ACP endpoint for rephrase-question and similar LLM features.
# If unset, these features fall back to deterministic alternatives.
# AVOCADOCORE_ACP_ENDPOINT=https://your-acp-server/api/...
# AVOCADOCORE_ACP_TOKEN=<token>

# Feedback provider for local LLM integration.
# For Frank's private frankavo instance only — do not set for prodavo.
# AVOCADOCORE_FEEDBACK_PROVIDER=local
# AVOCADOCORE_FEEDBACK_BASE_URL=http://127.0.0.1:8080/v1

# ── Next.js ───────────────────────────────────────────────────────────────────
# Port for next start (default 3000)
# PORT=3001
