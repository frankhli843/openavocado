# Open Avocado — environment configuration example.
# Copy to .env.local (gitignored) for local development, or set these in your
# deployment environment. Never commit real secrets.
#
# All variables use the AVOCADOCORE_ prefix for backward compatibility.

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file. The directory is created automatically.
# Default: data/avocadocore.db (relative to the working directory).
# AVOCADOCORE_DB_PATH=data/avocadocore.db

# Where generated audio and other runtime artifacts are stored (gitignored).
# Default: runtime_artifacts/ in the repository.
# AVOCADOCORE_RUNTIME_ROOT=runtime_artifacts

# ── Auth ─────────────────────────────────────────────────────────────────────
# "true" requires authentication for all pages and API routes.
# Local/trusted runs: leave "false". Hosted/public runs: set "true".
AVOCADOCORE_AUTH_REQUIRED=false

# Secret used to sign session tokens. Required when auth is required.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AVOCADOCORE_SESSION_SECRET=<64-char-hex-string>

# Optional bootstrap admin, created once on first startup if it does not exist.
# Set only in a deployment environment; never commit these values.
# AVOCADOCORE_ADMIN_BOOTSTRAP_USER=admin
# AVOCADOCORE_ADMIN_BOOTSTRAP_PASS=<strong-password>
# AVOCADOCORE_ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# AVOCADOCORE_ADMIN_BOOTSTRAP_DISPLAY=Administrator

# ── Lesson generation ────────────────────────────────────────────────────────
# How lessons are generated on subject.created / lesson.completed / lesson.discarded:
#   noop | local-queue | webhook | dora-task | agent-harness
# See https://frankhli843.github.io/openavocado/configuration.html
AVOCADOCORE_COMPLETION_ADAPTER=local-queue

# webhook adapter:
# AVOCADOCORE_WEBHOOK_URL=https://your-endpoint.example/hooks/lesson

# External agent/task-runner (dora-task) adapter:
# AVOCADOCORE_DORA_ENDPOINT=https://your-runner.example/tasks
# AVOCADOCORE_DORA_TODO_CLI=/path/to/your-task-cli
# AVOCADOCORE_DORA_PROJECT=openavocado

# Command (agent-harness) adapter — e.g. a local agent runtime wrapper:
# AVOCADOCORE_AGENT_HARNESS_COMMAND=/path/to/lesson-runner
# AVOCADOCORE_AGENT_HARNESS_TIMEOUT_MS=1800000

# ── Model providers / API keys (kept server-side) ────────────────────────────
# Simplest path: one cloud key. Keys are never sent to the browser.
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_STUDIO_API_KEY=...
# AVOCADOCORE_DEFAULT_PROVIDER=google-ai-studio    # or openai

# Secret used to encrypt per-user provider keys stored in the database.
# AVOCADOCORE_PROVIDER_KEY_SECRET=<random-secret>

# Instant learner feedback (grading, hints, code feedback). Point at a local
# OpenAI-compatible model gateway for a fully local run:
# AVOCADOCORE_FEEDBACK_PROVIDER=local
# AVOCADOCORE_FEEDBACK_BASE_URL=http://127.0.0.1:8080/v1
# AVOCADOCORE_FEEDBACK_MODEL=your-local-model

# OpenAI-compatible endpoint for question rephrasing / lightweight generation:
# AVOCADOCORE_ACP_ENDPOINT=http://127.0.0.1:8080/v1/chat/completions
# AVOCADOCORE_ACP_MODEL=your-local-model
# AVOCADOCORE_ACP_TOKEN=<token-if-required>

# ── Next.js ──────────────────────────────────────────────────────────────────
# Port for `next start` (default 3000).
# PORT=3000
