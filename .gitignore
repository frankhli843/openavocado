/code/
local_data/
instance/
artifacts/
generated/
uploads/
exports/
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal

# Generated media
*.mp3
*.wav
*.ogg
*.m4a

# Runtime and tooling
node_modules/
.venv/
venv/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.next/
dist/
build/
coverage/

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Next.js specifics
.vercel
next-env.d.ts
*.tsbuildinfo
out/
.pnpm-store/

# Runtime audio/artifacts (generated MP3s live under runtime_artifacts/audio/).
# Anchor the bare audio/ pattern to the repo root so it does NOT also ignore
# source directories like src/lib/audio/. Generated audio is still covered by
# runtime_artifacts/ above and *.mp3 elsewhere in this file.
runtime_artifacts/
/audio/

# Manim video pipeline (Phase 0-3) — venv, render output, review frames
.venv-manim/
manim/media/
manim/review/
manim/**/__pycache__/
*.pyc

# keep review.json QA evidence (frames stay ignored)
!manim/review/
!manim/review/**/
!manim/review/**/review.json
